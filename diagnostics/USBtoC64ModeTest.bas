10 PRINTCHR$(147):PRINT"USBTOC64 C64 TEST"
20 PRINT"PLUG ADAPTER INTO C64 PORT 2"
30 PRINT"MOVE MOUSE OR JOYSTICK"
40 PRINT"SPACE=PORT  R=RESET  Q=QUIT"
50 P=2:X=PEEK(54297):Y=PEEK(54298):MS=0:JS=0
60 GETK$:IFK$="Q"THENEND
70 IFK$=" "THENP=3-P:MS=0:JS=0
80 IFK$="R"THENMS=0:JS=0
90 J=PEEK(56320):IFP=1THENJ=PEEK(56321)
100 NX=PEEK(54297):NY=PEEK(54298)
110 MD=ABS(NX-X)+ABS(NY-Y):X=NX:Y=NY
120 DG=0:IF(J AND 1)=0THENDG=DG+1
130 IF(J AND 2)=0THENDG=DG+1
140 IF(J AND 4)=0THENDG=DG+1
150 IF(J AND 8)=0THENDG=DG+1
160 IF(J AND 16)=0THENDG=DG+1
170 IFMD>3THENMS=MS+2
180 IFDG=0THEN200
190 IFMD<4THENJS=JS+1
200 M$="UNSURE - MOVE DEVICE"
210 IFMS>JS+3THENM$="MOUSE MODE"
220 IFJS>MS+3THENM$="JOYSTICK MODE"
230 PRINTCHR$(19)
240 PRINT"USBTOC64 C64 TEST       "
250 PRINT"PORT";P;"  MODE ";M$;"     "
260 PRINT"POT X";NX;" Y";NY;" DELTA";MD;"   "
270 U$="--":IF(J AND 1)=0THENU$="UP"
280 D$="--":IF(J AND 2)=0THEND$="DN"
290 L$="--":IF(J AND 4)=0THENL$="LT"
300 R$="--":IF(J AND 8)=0THENR$="RT"
310 F$="--":IF(J AND 16)=0THENF$="FR"
320 PRINT"JOY ";U$;" ";D$;" ";L$;" ";R$;" ";F$;"      "
330 PRINT"MOUSE SCORE";MS;" JOY SCORE";JS;"   "
340 PRINT"LEFT BTN=FIRE RIGHT BTN=UP   "
350 PRINT"MIDDLE BTN=DOWN IN MOUSE MODE"
360 PRINT"SPACE PORT R RESET Q QUIT    "
370 FORT=1TO80:NEXT:GOTO60
